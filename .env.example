# =============================================================================
# EmalAuto — environment configuration
#   Copy to `.env` and fill in real values. DOTENV_PATH env can override path.
# =============================================================================

# ---------- Notion -----------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_VERSION=2022-06-28

# Notion column names (semantic key -> real column in your DB)
NOTION_COL_STATUS=OutReach Status
NOTION_COL_ACTION=Action
NOTION_COL_PLATFORM=Platform
NOTION_COL_INNOUT=InNOut
NOTION_COL_SENDER_EMAIL=FCAccount
NOTION_COL_SUBJECT=Outreach Subject
NOTION_COL_BODY=Outreach Body
NOTION_COL_PAYLOAD=Payload
NOTION_COL_COMPLETION_TIME=Completion Time
NOTION_COL_RESULT_REMARK=Result Remark
NOTION_COL_REPLY_STATUS=Reply Status
NOTION_COL_REPLY_BODY=Reply Body
NOTION_COL_REPLY_EMAIL=Reply Email
NOTION_COL_LAST_REPLY_TIME=Last Reply Time
# Date column: poller enqueues only when empty (= send ASAP) OR datetime ≤ now
NOTION_COL_TRIGGER_TIME=Trigger Time
NOTION_COL_TASK_ID=Task ID

# Notion enum values
NOTION_STATUS_TODO=Todo
NOTION_STATUS_IN_FLIGHT=Sending
NOTION_STATUS_SUCCESS=Success
NOTION_STATUS_FAILURE=Failure
NOTION_ACTION_SEND=Send Email
NOTION_ACTION_REPLY=Reply Email
# Action option written to the NEW row we create for each inbound reply. Auto-created in Notion if missing.
NOTION_ACTION_INBOUND_REPLY=Inbound Reply
# Reply Status option stamped on the ORIGINAL outbound row once an inbound reply has a child row.
NOTION_REPLY_STATUS_DONE=Done
NOTION_PLATFORM_VALUE=Email
NOTION_IN_N_OUT_VALUE=Out
# Optional: InNOut option used on the inbound-reply child row. Default "In".
NOTION_IN_N_OUT_INBOUND_VALUE=In

# ---------- Graph Apps (one per email domain) --------------------------------
# Indexed from 1, scan stops at first missing _DOMAIN. Add as many as you need.
GRAPH_APP_1_DOMAIN=yourdomain.com
GRAPH_APP_1_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_APP_1_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_APP_1_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GRAPH_APP_2_DOMAIN=another-domain.com
# GRAPH_APP_2_TENANT_ID=...
# GRAPH_APP_2_CLIENT_ID=...
# GRAPH_APP_2_CLIENT_SECRET=...

# Shared Graph defaults (rarely changed; sovereign clouds may differ)
GRAPH_SCOPES=https://graph.microsoft.com/.default
GRAPH_AUTHORITY=https://login.microsoftonline.com

# ---------- Mailboxes ----------------------------------------------
# NOT in .env. Managed directly in the `mailboxes` table in Postgres
# (Supabase Studio -> Table editor -> mailboxes). Columns:
#   email, enabled, can_send, can_receive
# The domain part of `email` must match one GRAPH_APP_<N>_DOMAIN above.

# Folders watched on each mailbox (CSV; Graph well-known names)
FOLDERS=inbox,junkemail

# ---------- Polling / concurrency -------------------------------------------
POLL_NOTION_INTERVAL_MS=15000
POLL_INBOX_INTERVAL_MS=30000
TOKEN_WARM_SKEW_MS=300000
SEND_CONCURRENCY=4
INBOX_CONCURRENCY=4
MATCH_CONCURRENCY=8

# ---------- Postgres (Supabase / RDS / local) --------------------------------
# Supabase examples (use the "Connection string" / Transaction pooler URI):
#   postgresql://postgres.<PROJECT>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
#   postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres?sslmode=require
# SSL is auto-enabled for non-local hosts.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/emalauto
PG_MAX_POOL=10

# ---------- Redis (BullMQ — required) ----------------------------------------
# Quickest local setup:
#   docker run -d --name emalauto-redis -p 6379:6379 redis:7
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- HTTP server ------------------------------------------------------
SERVER_HOST=127.0.0.1
SERVER_PORT=3737

# ---------- Logging ----------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true

# ---------- V2 Webhook + Delta (optional) ------------------------------------
V2_ENABLED=false
V2_PUBLIC_BASE_URL=https://your-public-host.example.com
V2_WEBHOOK_PATH=/webhooks/graph
V2_CLIENT_STATE_SECRET=change-me-16chars
V2_RENEW_LEAD_HOURS=12
V2_DELTA_SYNC_INTERVAL_MS=300000
V2_DISABLE_POLLING_WHEN_V2=false
