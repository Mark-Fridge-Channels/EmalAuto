# =============================================================================
# EmalAuto — environment configuration
#   Copy to `.env` and fill in real values. DOTENV_PATH env can override path.
# =============================================================================

# ---------- Notion -----------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_VERSION=2022-06-28

# Notion column names (semantic key -> real column in your DB)
NOTION_COL_STATUS=OutReach Status
NOTION_COL_ACTION=Action
NOTION_COL_PLATFORM=Platform
NOTION_COL_INNOUT=InNOut
NOTION_COL_SENDER_EMAIL=FCAccount
NOTION_COL_SUBJECT=Outreach Subject
NOTION_COL_BODY=Outreach Body
NOTION_COL_PAYLOAD=Payload
NOTION_COL_COMPLETION_TIME=Completion Time
NOTION_COL_RESULT_REMARK=Result Remark
NOTION_COL_REPLY_STATUS=Reply Status
NOTION_COL_REPLY_BODY=Reply Body
NOTION_COL_REPLY_EMAIL=Reply Email
NOTION_COL_LAST_REPLY_TIME=Last Reply Time
# Date column: poller enqueues only when empty (= send ASAP) OR datetime ≤ now
NOTION_COL_TRIGGER_TIME=Trigger Time
NOTION_COL_TASK_ID=Task ID
# Comma-separated Cc (Send Email / Reply Email); Interaction LOG rich_text column
NOTION_COL_CC=cc

# Interaction LOG → DTC send gate (Send Email only)
NOTION_IL_DTC_ENTITY=DTC Entity
NOTION_IL_DTC_KEY_PERSON=DTC Key Person
NOTION_IL_CURRENT_STATUS=Current Status
NOTION_IL_TARGET_STATUS=Target Status
NOTION_DTC_ENTITY_COL_COLD_REACH=ColdReach Status
NOTION_DTC_KP_COL_EMAIL=Email
NOTION_DTC_KP_COL_EMAIL_VERIFIED=Email Verified Status
NOTION_DTC_KP_EMAIL_VERIFIED_VALUE=Verified
# DTC Key Person Email Verified Status when a bounce is matched to outbound
NOTION_DTC_KP_EMAIL_FAILED_VALUE=Send Email Failed
# Max days to search outbound by failed recipient when matching bounces (default: LEGACY_MATCH_MAX_DAYS or 30)
# BOUNCE_MATCH_MAX_DAYS=30
# DTC Entity ColdReach Status when a human (non-auto) inbound reply is matched
NOTION_DTC_HUMAN_REPLY_COLD_REACH=Humen
# DTC 关联页 → Supabase CRM 列（Key Person: 公式 ID + Title name；Entity: Title Entity Name）
NOTION_IL_SYNC_KP_ID_PROP=ID
NOTION_IL_SYNC_KP_NAME_PROP=name
NOTION_IL_SYNC_ENTITY_NAME_PROP=Entity Name

# Notion enum values
NOTION_STATUS_TODO=Todo
NOTION_STATUS_IN_FLIGHT=Sending
NOTION_STATUS_SUCCESS=Success
NOTION_STATUS_FAILURE=Failure
NOTION_ACTION_SEND=Send Email
NOTION_ACTION_REPLY=Reply Email
# Action option written to the NEW row we create for each inbound reply. Auto-created in Notion if missing.
NOTION_ACTION_INBOUND_REPLY=Inbound Reply
# Reply Status option stamped on the ORIGINAL outbound row once an inbound reply has a child row.
NOTION_REPLY_STATUS_DONE=Done
NOTION_PLATFORM_VALUE=Email
NOTION_IN_N_OUT_VALUE=Out
# Optional: InNOut option used on the inbound-reply child row. Default "In".
NOTION_IN_N_OUT_INBOUND_VALUE=In

# Optional: copy KeyPerson / Entity from Notion into Postgres (exact column names; leave empty to skip)
NOTION_COL_KEYPERSON_ID=
NOTION_COL_KEYPERSON_NAME=KeyPerson ID
NOTION_COL_KEYPERSON_URL=KeyPerson ID
NOTION_COL_ENTITY_NAME=Entity Name
NOTION_COL_ENTITY_URL=Entity Name

# Optional: one-shot `npm run backfill:outbound` — Interaction LOG DB + relation column linking each IL row → Outreach task page
# NOTION_INTERACTION_LOG_DATABASE_ID=
# NOTION_IL_OUTREACH_RELATION_PROP=
#
# `npm run sync:outbound-crm-il` — 用 outbound_messages.notion_page_id（**IL 行 id**）拉 Relation → KeyPerson / Entity 页，补全 key_person_* / entity_*（见 scripts/sync-outbound-crm-from-interaction-log.ts 头注释）
# `npm run debug:notion-il-sample` — 打印一条 IL + 关联 KP/Entity 的各列类型与摘要（可选 DEBUG_IL_PAGE_ID）
# NOTION_IL_KP_RELATION=KeyPerson ID
# NOTION_IL_ENTITY_RELATION=Entity Name
# 可选：校验 notion_page_id 必须属于该 IL 库（parent.database_id）
# NOTION_INTERACTION_LOG_DATABASE_ID=
# 可选：关联页上的列名（不设则用 Title / Unique ID）。样本库中 Key Person 有公式列 ID、Title 列 name；Entity 的 Title 列为「Entity Name」：
# NOTION_IL_SYNC_KP_ID_PROP=ID
# NOTION_IL_SYNC_KP_NAME_PROP=name
# NOTION_IL_SYNC_ENTITY_NAME_PROP=Entity Name
# SYNC_IL_CRM_OVERWRITE=1
# SYNC_IL_CRM_LIMIT=50
# Legacy rows without Payload._graph: relax subject/body match, or skip that check (risky)
# BACKFILL_LEGACY_RELAXED_COMPARE=1
# BACKFILL_LEGACY_SKIP_SUBJECT_BODY=1
# CRM from Payload JSON when Notion CRM columns are empty (see script mergeCrmFromPayloadIfEnabled)
# BACKFILL_CRM_FROM_PAYLOAD=1
# Resolve real Graph ids from Sent Items (mailbox = FCAccount; subject + to_email must match Sent Items exactly)
# BACKFILL_LEGACY_RESOLVE_GRAPH=1
# Hours on EACH side of Notion Completion time; use 0 = no sentDateTime filter (newest-first scan, see BACKFILL_GRAPH_SENT_SCAN_MAX)
BACKFILL_GRAPH_SEARCH_WINDOW_HOURS=0
# When SEARCH_WINDOW_HOURS=0: max messages to read across Graph pages (cannot scan infinite history in one run)
# BACKFILL_GRAPH_SENT_SCAN_MAX=5000
# After outbound backfill: `npm run reconcile:inbox` (see scripts/reconcile-inbox-after-outbound-backfill.ts)
# RECONCILE_HEURISTIC=0          # default on: mailbox+subject+party heuristic link (no Notion)
# RECONCILE_HEURISTIC_RELAXED_SUBJECT=1
# RECONCILE_HEURISTIC_MAX_DAYS=365
# REQUEUE_MATCH_FOR_CONVERSATION=1   # optional: Graph conversation_id + match worker (Notion side effects)
# REQUEUE_MATCH_LEGACY_INBOX=1       # re-enqueue ignored|unmatched inbox for match worker (legacy heuristic + status sync)
# npm run sync:thread-status-from-inbox   # one-shot: inbox matched → outbound thread_status

# Runtime legacy reply match (match worker; when conversationId misses notion-legacy rows)
# LEGACY_MATCH_MAX_DAYS=365
# LEGACY_MATCH_RELAXED_SUBJECT=0

# ---------- Graph Apps (one per email domain) --------------------------------
# Source: `env` = GRAPH_APP_<N>_* below; `db` = `graph_apps` Postgres table (hot-reload).
GRAPH_APPS_SOURCE=env
# Indexed from 1, scan stops at first missing _DOMAIN. Add as many as you need.
GRAPH_APP_1_DOMAIN=yourdomain.com
GRAPH_APP_1_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_APP_1_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_APP_1_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GRAPH_APP_2_DOMAIN=another-domain.com
# GRAPH_APP_2_TENANT_ID=...
# GRAPH_APP_2_CLIENT_ID=...
# GRAPH_APP_2_CLIENT_SECRET=...

# Shared Graph defaults (rarely changed; sovereign clouds may differ)
GRAPH_SCOPES=https://graph.microsoft.com/.default
GRAPH_AUTHORITY=https://login.microsoftonline.com

# ---------- Mailboxes ----------------------------------------------
# NOT in .env. Managed directly in the `mailboxes` table in Postgres
# (Supabase Studio -> Table editor -> mailboxes). Columns:
#   email, enabled, can_send, can_receive
# The domain part of `email` must match one GRAPH_APP_<N>_DOMAIN above.

# Folders watched on each mailbox (CSV; Graph well-known names)
FOLDERS=inbox,junkemail

# ---------- Polling / concurrency -------------------------------------------
POLL_NOTION_INTERVAL_MS=15000
POLL_INBOX_INTERVAL_MS=30000
TOKEN_WARM_SKEW_MS=300000
SEND_CONCURRENCY=4
INBOX_CONCURRENCY=4
MATCH_CONCURRENCY=8

# ---------- Postgres (Supabase / RDS / local) --------------------------------
# Supabase examples (use the "Connection string" / Transaction pooler URI):
#   postgresql://postgres.<PROJECT>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?sslmode=require
#   postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres?sslmode=require
# SSL is auto-enabled for non-local hosts.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/emalauto
PG_MAX_POOL=10

# ---------- Redis (BullMQ — required) ----------------------------------------
# Quickest local setup:
#   docker run -d --name emalauto-redis -p 6379:6379 redis:7
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- HTTP server ------------------------------------------------------
SERVER_HOST=127.0.0.1
SERVER_PORT=3737

# ---------- Admin Web UI (optional) -----------------------------------------
# When set, `/api/*` JSON API + Vite `web/dist` static UI are enabled (session cookie).
ADMIN_UI_PASSWORD=
# Min 16 chars; used only if ADMIN_UI_PASSWORD is non-empty.
ADMIN_SESSION_SECRET=dev-change-me-32chars-minimum!
# Session cookie lifetime (days). Stored in Redis — survives API restarts until logout or expiry.
ADMIN_SESSION_MAX_AGE_DAYS=30

# ---------- Logging ----------------------------------------------------------
LOG_LEVEL=info
LOG_PRETTY=true

# ---------- V2 Webhook + Delta (optional) ------------------------------------
V2_ENABLED=false
V2_PUBLIC_BASE_URL=https://your-public-host.example.com
V2_WEBHOOK_PATH=/webhooks/graph
V2_CLIENT_STATE_SECRET=change-me-16chars
V2_RENEW_LEAD_HOURS=12
V2_DELTA_SYNC_INTERVAL_MS=300000
V2_DISABLE_POLLING_WHEN_V2=false
