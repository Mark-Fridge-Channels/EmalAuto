{
  "name": "emal-auto",
  "version": "0.1.0",
  "private": true,
  "description": "M365 multi-mailbox orchestration: Graph App-only send/receive, conversationId-based reply matching, bounce detection, Notion sync.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "smoke:send": "tsx scripts/smoke-send.ts",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^2.16.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@notionhq/client": "^2.2.15",
    "bullmq": "^5.21.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "isomorphic-fetch": "^3.0.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
